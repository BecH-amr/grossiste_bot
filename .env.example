# Get your token from @BotFather on Telegram
BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrsTUVwxyz

# Webhook settings (prod) — leave WEBHOOK_URL empty for polling mode
WEBHOOK_URL=https://yourdomain.com
# REQUIRED — generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_TOKEN=

# SQLite database path
DB_URL=sqlite+aiosqlite:///./catalog.db

# Set to "true" for local development (no domain/webhook needed)
USE_POLLING=true


# Your contact info shown to customers
CONTACT_SNAPCHAT=@your_snapchat
